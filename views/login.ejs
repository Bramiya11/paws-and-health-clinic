<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">🐾 Bienvenido</h2>
                <p class="text-center text-muted mb-4">Paws & Health Clinic</p>

                <% if (error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="username" class="form-label">Usuario</label>
                        <input type="text" class="form-control" id="username"
                               name="username" required placeholder="Ej: dr.lopez">
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" class="form-control" id="password"
                               name="password" required placeholder="••••••••">
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Ingresar</button>
                    </div>
                </form>

                <hr class="my-3">
                <p class="text-center text-muted small mb-0">
                    🔑 Usuarios de prueba:<br>
                    <code>dr.lopez / 1234</code> — Veterinario<br>
                    <code>recepcion / 1234</code> — Recepcionista
                </p>
            </div>
        </div>
    </div>
</div>